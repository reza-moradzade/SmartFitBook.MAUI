    }
    
    .exercises-list::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
    }
    
    .exercises-list::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 10px;
    }
    
    @@media (max-width: 480px) {
        .exercise-thumb {
            width: 50px;
            height: 50px;
        }
        .exercise-name {
            font-size: 13px;
        }
        .save-btn, .share-btn {
            padding: 12px;
            font-size: 13px;
        }
    }
</style>

@code {
    [Parameter] public string? Trainee { get; set; }
    
    private string _traineeName = "";
    private DateTime _startDate = DateTime.Today;
    private int _weeksCount = 4;
    private List<string> _weekDays = new();
    private List<string> _allDays = new() { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    private string _selectedDay = "";
    private WorkoutPlan _plan = new();
    private bool _showExerciseSelector = false;
    private bool _showEditDialog = false;
    private bool _isSaving = false;
    
    private int _editIndex = -1;
    private int _editSets = 3;
    private string _editReps = "10-12";
    private int _editRestSeconds = 60;
    private string _editTrainerNote = "";
    
    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        
        _traineeName = query["trainee"] ?? Trainee ?? "";
        
        _weeksCount = 4;
        _weekDays = new List<string>();
        _startDate = DateTime.Today;
        
        CreateNewPlan();
        
        await base.OnInitializedAsync();
    }
    
    private void CreateNewPlan()
    {
        _plan = new WorkoutPlan
        {
            WorkoutId = Guid.NewGuid().ToString(),
            TraineeUsername = _traineeName,
            CreatedBy = AuthService.CurrentUser?.Username ?? "",
            StartDate = _startDate,
            Weeks = _weeksCount,
            WeekDays = _weekDays,
            Schedule = new Dictionary<string, List<WorkoutDayItem>>(),
            CreatedAt = DateTime.UtcNow,
            IsActive = true
        };
        
        foreach (var day in _weekDays)
        {
            _plan.Schedule[day] = new List<WorkoutDayItem>();
        }
        
        if (_weekDays.Any())
        {
            _selectedDay = _weekDays.First();
        }
    }
    
    private void UpdatePlanSettings()
    {
        _plan.StartDate = _startDate;
        _plan.Weeks = _weeksCount;
        _plan.WeekDays = _weekDays;
        
        foreach (var day in _weekDays)
        {
            if (!_plan.Schedule.ContainsKey(day))
            {
                _plan.Schedule[day] = new List<WorkoutDayItem>();
            }
        }
        
        var daysToRemove = _plan.Schedule.Keys.Where(d => !_weekDays.Contains(d)).ToList();
        foreach (var day in daysToRemove)
        {
            _plan.Schedule.Remove(day);
        }
        
        if (!string.IsNullOrEmpty(_selectedDay) && !_weekDays.Contains(_selectedDay))
        {
            _selectedDay = _weekDays.FirstOrDefault() ?? "";
        }
        
        StateHasChanged();
    }
    
    private void ToggleDay(string day, bool isChecked)
    {
        if (isChecked)
        {
            if (!_weekDays.Contains(day))
                _weekDays.Add(day);
        }
        else
        {
            _weekDays.Remove(day);
        }
        UpdatePlanSettings();
    }
    
    private void SelectDay(string day)
    {
        _selectedDay = day;
        _showExerciseSelector = false;
        StateHasChanged();
    }
    
    private async Task OnExerciseSelectedHandler(Exercise exercise)
    {
        if (!string.IsNullOrEmpty(_selectedDay))
        {
            var item = new WorkoutDayItem
            {
                ExerciseId = exercise.ExerciseId,
                Name = exercise.Name,
                GifUrl = exercise.GifUrl,
                Sets = 3,
                Reps = "10-12",
                RestSeconds = 60,
                TrainerNote = null,
                Instructions = exercise.Instructions
            };
            
            _plan.Schedule[_selectedDay].Add(item);
            _showExerciseSelector = false;
            StateHasChanged();
        }
        await Task.CompletedTask;
    }
    
    private void EditExercise(int index)
    {
        _editIndex = index;
        var item = _plan.Schedule[_selectedDay][index];
        _editSets = item.Sets;
        _editReps = item.Reps;
        _editRestSeconds = item.RestSeconds;
        _editTrainerNote = item.TrainerNote ?? "";
        _showEditDialog = true;
        StateHasChanged();
    }
    
    private void SaveExerciseEdit()
    {
        if (_editIndex >= 0 && _plan.Schedule.ContainsKey(_selectedDay))
        {
            var item = _plan.Schedule[_selectedDay][_editIndex];
            item.Sets = _editSets;
            item.Reps = _editReps;
            item.RestSeconds = _editRestSeconds;
            item.TrainerNote = string.IsNullOrWhiteSpace(_editTrainerNote) ? null : _editTrainerNote;
        }
        CloseEditDialog();
        StateHasChanged();
    }
    
    private void CloseEditDialog()
    {
        _showEditDialog = false;
        _editIndex = -1;
        StateHasChanged();
    }
    
    private void RemoveExercise(int index)
    {
        if (_plan.Schedule.ContainsKey(_selectedDay) && index < _plan.Schedule[_selectedDay].Count)
        {
            _plan.Schedule[_selectedDay].RemoveAt(index);
            StateHasChanged();
        }
    }
    
    private async Task SaveWorkout()
    {
        if (!_weekDays.Any())
        {
            await App.Current!.MainPage!.DisplayAlert("خطا", "لطفاً حداقل یک روز تمرین انتخاب کنید", "باشه");
            return;
        }
        
        _isSaving = true;
        StateHasChanged();
        
        _plan.StartDate = _startDate;
        
        var saved = await WorkoutService.SaveWorkoutToDatabaseAsync(_plan);
        
        if (saved)
        {
            var json = WorkoutService.ExportWorkoutToJson(_plan);
            var fileName = $"workout_{_plan.TraineeUsername}_{_startDate:yyyyMMdd}_{DateTime.Now:HHmmss}.json";
            var filePath = Path.Combine(FileSystem.AppDataDirectory, fileName);
            await File.WriteAllTextAsync(filePath, json);
            
            await App.Current!.MainPage!.DisplayAlert("ذخیره شد", 
                $"برنامه از تاریخ {_startDate:yyyy/MM/dd} برای {_plan.TraineeUsername} ذخیره شد.", "باشه");
            
            Navigation.NavigateTo("/trainer/dashboard");
        }
        else
        {
            await App.Current!.MainPage!.DisplayAlert("خطا", "خطا در ذخیره برنامه", "باشه");
        }
        
        _isSaving = false;
        StateHasChanged();
    }
    
    private async Task ExportAndShare()
    {
        if (!_weekDays.Any())
        {
            await App.Current!.MainPage!.DisplayAlert("خطا", "لطفاً حداقل یک روز تمرین انتخاب کنید", "باشه");
            return;
        }
        
        _isSaving = true;
        StateHasChanged();
        
        _plan.StartDate = _startDate;
        var json = WorkoutService.ExportWorkoutToJson(_plan);
        var fileName = $"workout_{_plan.TraineeUsername}_{_startDate:yyyyMMdd}.json";
        var filePath = Path.Combine(FileSystem.AppDataDirectory, fileName);
        
        await File.WriteAllTextAsync(filePath, json);
        
        _isSaving = false;
        StateHasChanged();
        
        var result = await App.Current!.MainPage!.DisplayAlert(
            "✅ فایل ذخیره شد", 
            $"برنامه با نام '{fileName}' در حافظه گوشی ذخیره شد.\n\nآیا مایل به ارسال فایل هستید؟", 
            "بله، ارسال کن", 
            "فقط ذخیره شود");
        
        if (result)
        {
            await Share.Default.RequestAsync(new ShareFileRequest
            {
                Title = $"برنامه تمرینی {_plan.TraineeUsername} - شروع {_startDate:yyyy/MM/dd}",
                File = new ShareFile(filePath)
            });
        }
        else
        {
            await App.Current!.MainPage!.DisplayAlert("اطلاع", $"فایل '{fileName}' در حافظه گوشی ذخیره شد.", "باشه");
        }
    }
    
    private string GetDayName(string day)
    {
        var persianDays = new Dictionary<string, string>
        {
            { "Monday", "دوشنبه" }, { "Tuesday", "سه‌شنبه" }, { "Wednesday", "چهارشنبه" },
            { "Thursday", "پنج‌شنبه" }, { "Friday", "جمعه" }, { "Saturday", "شنبه" }, { "Sunday", "یکشنبه" }
        };
        return persianDays.ContainsKey(day) ? persianDays[day] : day;
    }
    
    private void GoBack()
    {
        Navigation.NavigateTo("/trainer/dashboard");
    }
}