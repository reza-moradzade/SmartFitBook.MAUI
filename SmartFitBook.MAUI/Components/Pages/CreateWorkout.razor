@page "/trainer/create-workout"
@using SmartFitBook.MAUI.Services
@using SmartFitBook.MAUI.Models
@inject AuthService AuthService
@inject WorkoutService WorkoutService
@inject DataService DataService
@inject NavigationManager Navigation

<PageTitle>ساخت برنامه تمرینی | برنامه بدنسازی</PageTitle>

<div class="create-workout-container">
    <!-- هدر -->
    <div class="page-header">
        <button class="back-btn" @onclick="GoBack">
            <span>←</span> بازگشت
        </button>
        <h2>📝 ساخت برنامه تمرینی جدید</h2>
    </div>

    @if (!string.IsNullOrEmpty(_traineeName))
    {
        <!-- کارت اطلاعات شاگرد -->
        <div class="info-card">
            <div class="info-row">
                <span class="info-label">👤 شاگرد:</span>
                <span class="info-value">@_traineeName</span>
            </div>
            <div class="info-row">
                <span class="info-label">📅 تاریخ شروع:</span>
                <span class="info-value">@_startDate.ToString("yyyy/MM/dd")</span>
            </div>
            <div class="info-row">
                <span class="info-label">⏱️ مدت:</span>
                <span class="info-value">@_weeksCount هفته</span>
            </div>
            <div class="info-row">
                <span class="info-label">📆 روزهای تمرین:</span>
                <span class="info-value">@string.Join(", ", _weekDays.Select(GetDayName))</span>
            </div>
        </div>

        <!-- بخش تنظیمات برنامه -->
        <div class="settings-card">
            <div class="card-title">⚙️ تنظیمات برنامه</div>
            <div class="settings-grid">
                <div class="setting-item">
                    <label class="setting-label">📅 تاریخ شروع</label>
                    <input type="date" @bind="_startDate" @bind:format="yyyy-MM-dd" class="modern-input" />
                </div>
                <div class="setting-item">
                    <label class="setting-label">⏱️ تعداد هفته‌ها</label>
                    <select @bind="_weeksCount" class="modern-select">
                        <option value="4">4 هفته</option>
                        <option value="6">6 هفته</option>
                        <option value="8">8 هفته</option>
                        <option value="12">12 هفته</option>
                        <option value="16">16 هفته</option>
                        <option value="20">20 هفته</option>
                        <option value="24">24 هفته (6 ماه)</option>
                        <option value="52">52 هفته (1 سال)</option>
                    </select>
                </div>
                <div class="setting-item full-width">
                    <label class="setting-label">📆 روزهای تمرین</label>
                    <div class="days-grid">
                        @foreach (var day in _allDays)
                        {
                            <label class="day-checkbox">
                                <input type="checkbox" 
                                       value="@day" 
                                       checked="@_weekDays.Contains(day)" 
                                       @onchange="(ChangeEventArgs e) => ToggleDay(day, e.Value is bool isChecked && isChecked)" />
                                <span>@GetDayName(day)</span>
                            </label>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- بخش اصلی: روزها و حرکات -->
        <div class="main-workout-row">
            <!-- لیست روزها -->
            <div class="days-sidebar">
                <div class="sidebar-title">📅 روزهای تمرین</div>
                <div class="days-list">
                    @foreach (var day in _weekDays)
                    {
                        <div class="day-item @(day == _selectedDay ? "active" : "")"
                             @onclick="() => SelectDay(day)">
                            <span class="day-name">@GetDayName(day)</span>
                            <span class="day-count">@(_plan.Schedule.ContainsKey(day) ? _plan.Schedule[day].Count : 0)</span>
                        </div>
                    }
                </div>
            </div>

            <!-- حرکات روز انتخاب شده -->
            <div class="exercises-content">
                @if (!string.IsNullOrEmpty(_selectedDay))
                {
                    <div class="exercises-card">
                        <div class="exercises-header">
                            <span>🏋️‍♂️ حرکات روز @GetDayName(_selectedDay)</span>
                            <button class="add-exercise-btn" @onclick="() => _showExerciseSelector = true">
                                + افزودن حرکت
                            </button>
                        </div>
                        <div class="exercises-list">
                            @if (_plan.Schedule.ContainsKey(_selectedDay) && _plan.Schedule[_selectedDay].Any())
                            {
                                @foreach (var item in _plan.Schedule[_selectedDay].Select((value, index) => new { value, index }))
                                {
                                    <div class="exercise-item">
                                        <div class="exercise-info">
                                            <div class="exercise-thumb">
                                                @if (!string.IsNullOrEmpty(item.value.GifFileName))
                                                {
                                                    <img src="@($"media/{item.value.GifFileName}")" 
                                                         alt="@item.value.Name"
                                                         class="exercise-thumb-img" />
                                                }
                                                else
                                                {
                                                    <div class="exercise-thumb-placeholder">🏋️</div>
                                                }
                                            </div>
                                            <div class="exercise-details">
                                                <div class="exercise-name">@item.value.Name</div>
                                                <div class="exercise-stats">
                                                    ست: @item.value.Sets | تکرار: @item.value.Reps | استراحت: @item.value.RestSeconds ثانیه
                                                </div>
                                                @if (!string.IsNullOrEmpty(item.value.TrainerNote))
                                                {
                                                    <div class="exercise-note">📝 @item.value.TrainerNote</div>
                                                }
                                            </div>
                                        </div>
                                        <div class="exercise-actions">
                                            <button class="action-edit" @onclick="() => EditExercise(item.index)" title="ویرایش">✏️</button>
                                            <button class="action-delete" @onclick="() => RemoveExercise(item.index)" title="حذف">🗑️</button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="empty-exercises">
                                    <div class="empty-icon">🏋️</div>
                                    <p>هنوز حرکتی برای این روز اضافه نشده است</p>
                                    <button class="add-exercise-btn empty" @onclick="() => _showExerciseSelector = true">
                                        + افزودن حرکت
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- دکمه‌های ذخیره -->
                <div class="save-actions">
                    <button class="save-btn" @onclick="SaveWorkout" disabled="@_isSaving">
                        💾 ذخیره برنامه
                    </button>
                    <button class="share-btn" @onclick="ExportAndShare" disabled="@_isSaving">
                        📤 ارسال برای شاگرد
                    </button>
                </div>
                <div class="save-hint">
                    برنامه برای تاریخ @_startDate.ToString("yyyy/MM/dd") شروع می‌شود
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="error-card">
            <div class="error-icon">⚠️</div>
            <h3>اطلاعات کافی برای ساخت برنامه وجود ندارد</h3>
            <button class="back-btn-primary" @onclick="GoBack">بازگشت به داشبورد</button>
        </div>
    }

    <!-- مودال انتخاب حرکت -->
    @if (_showExerciseSelector)
    {
        <div class="modal-overlay">
            <div class="modal-container modal-lg">
                <div class="modal-header">
                    <h3>انتخاب حرکت ورزشی</h3>
                    <button class="modal-close" @onclick="() => _showExerciseSelector = false">✖</button>
                </div>
                <div class="modal-body">
                    <ExerciseSelector OnExerciseSelected="OnExerciseSelectedHandler" />
                </div>
            </div>
        </div>
    }

    <!-- مودال ویرایش حرکت -->
    @if (_showEditDialog)
    {
        <div class="modal-overlay">
            <div class="modal-container">
                <div class="modal-header">
                    <h3>✏️ ویرایش حرکت</h3>
                    <button class="modal-close" @onclick="CloseEditDialog">✖</button>
                </div>
                <div class="modal-body">
                    <div class="edit-field">
                        <label>تعداد ست</label>
                        <input type="number" @bind="_editSets" class="modern-input" min="1" max="10" />
                    </div>
                    <div class="edit-field">
                        <label>تعداد تکرار</label>
                        <input type="text" @bind="_editReps" class="modern-input" placeholder="مثلاً: 8-12" />
                    </div>
                    <div class="edit-field">
                        <label>استراحت (ثانیه)</label>
                        <input type="number" @bind="_editRestSeconds" class="modern-input" min="30" max="180" step="15" />
                    </div>
                    <div class="edit-field">
                        <label>توضیح مربی (اختیاری)</label>
                        <textarea @bind="_editTrainerNote" class="modern-textarea" rows="3" placeholder="نکته خاصی برای این حرکت دارید؟"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn-cancel" @onclick="CloseEditDialog">انصراف</button>
                    <button class="btn-save" @onclick="SaveExerciseEdit">ذخیره تغییرات</button>
                </div>
            </div>
        </div>
    }
</div>

